{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icon/**",
              "components/navigation/**",
              "components/system/**",
              "documents/**",
              "events/**",
              "ui_kits/_shared/**",
              "ui_kits/admin/**",
              "ui_kits/controlapp/**",
              "ui_kits/reportapp/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|Roboto Mono|Roboto))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, Roboto Mono, Roboto."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:severity|title|children|icon|onClose|style|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: severity, title, children, icon, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='severity'] > Literal[value!=/^(?:success|warning|danger|info)$/]",
        "message": "<Alert> severity must be one of 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|warning|danger|info|accent|neutral)$/]",
        "message": "<Badge> tone must be one of 'success' | 'warning' | 'danger' | 'info' | 'accent' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomSheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|children|footer|maxHeight|key|ref|className|style|children)$/]",
        "message": "<BottomSheet> doesn't accept that prop. Declared props: open, onClose, title, children, footer, maxHeight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|fullWidth|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|danger|text)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'danger' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padding|accent|as|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padding, accent, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:warning|danger|success|accent)$/]",
        "message": "<Card> accent must be one of 'warning' | 'danger' | 'success' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|align|width|key|ref|className|style|children)$/]",
        "message": "<DataTableColumn> doesn't accept that prop. Declared props: id, label, align, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<DataTableColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DocFormat'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<DocFormat> doesn't accept that prop. Declared props: type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageGeom'] > JSXAttribute > JSXIdentifier[name!=/^(?:w|h|key|ref|className|style|children)$/]",
        "message": "<PageGeom> doesn't accept that prop. Declared props: w, h."
      },
      {
        "selector": "JSXOpeningElement[name.name='DocStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|tone|key|ref|className|style|children)$/]",
        "message": "<DocStatus> doesn't accept that prop. Declared props: label, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='DocStatus'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|warning|success|danger|neutral|accent)$/]",
        "message": "<DocStatus> tone must be one of 'info' | 'warning' | 'success' | 'danger' | 'neutral' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventLog'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|meta|status|time|hasFile|onClick|style|key|ref|className|style|children)$/]",
        "message": "<EventLog> doesn't accept that prop. Declared props: type, title, meta, status, time, hasFile, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Fab'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|tone|fixed|key|ref|className|style|children)$/]",
        "message": "<Fab> doesn't accept that prop. Declared props: icon, label, tone, fixed."
      },
      {
        "selector": "JSXOpeningElement[name.name='Fab'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|danger)$/]",
        "message": "<Fab> tone must be one of 'accent' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|titleIcon|onClear|columns|children|style|key|ref|className|style|children)$/]",
        "message": "<FilterBar> doesn't accept that prop. Declared props: title, titleIcon, onClear, columns, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HapticPatterns'] > JSXAttribute > JSXIdentifier[name!=/^(?:success|error|scan|tap|key|ref|className|style|children)$/]",
        "message": "<HapticPatterns> doesn't accept that prop. Declared props: success, error, scan, tap."
      },
      {
        "selector": "JSXOpeningElement[name.name='HoldButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:duration|onComplete|tone|icon|label|holdingLabel|placement|haptics|style|key|ref|className|style|children)$/]",
        "message": "<HoldButton> doesn't accept that prop. Declared props: duration, onComplete, tone, icon, label, holdingLabel, placement, haptics, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HoldButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:danger|accent|success)$/]",
        "message": "<HoldButton> tone must be one of 'danger' | 'accent' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HoldButton'] > JSXAttribute[name.name='placement'] > Literal[value!=/^(?:page|floating|header)$/]",
        "message": "<HoldButton> placement must be one of 'page' | 'floating' | 'header'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|tone|title|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, tone, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|htmlFor|required|children|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, hint, error, htmlFor, required, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|kicker|title|children|footer|width|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, onClose, kicker, title, children, footer, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|description|titleIcon|count|countLabel|lastUpdate|onRefresh|actions|style|key|ref|className|style|children)$/]",
        "message": "<PageHeader> doesn't accept that prop. Declared props: eyebrow, title, description, titleIcon, count, countLabel, lastUpdate, onRefresh, actions, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableControls'] > JSXAttribute > JSXIdentifier[name!=/^(?:limit|options|onLimitChange|shown|total|style|key|ref|className|style|children)$/]",
        "message": "<TableControls> doesn't accept that prop. Declared props: limit, options, onLimitChange, shown, total, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PushIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|onHeader|size|style|key|ref|className|style|children)$/]",
        "message": "<PushIndicator> doesn't accept that prop. Declared props: status, onHeader, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusOverlay'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|status|title|message|description|buttonText|onClose|icon|key|ref|className|style|children)$/]",
        "message": "<StatusOverlay> doesn't accept that prop. Declared props: open, status, title, message, description, buttonText, onClose, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusOverlay'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:success|danger|accent)$/]",
        "message": "<StatusOverlay> status must be one of 'success' | 'danger' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
